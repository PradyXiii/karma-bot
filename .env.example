# Anthropic API key (https://console.anthropic.com)
ANTHROPIC_API_KEY=sk-ant-...

# Reddit account credentials
REDDIT_USERNAME=your_reddit_username
# Get this from browser devtools on old.reddit.com:
#   Application > Cookies > reddit_session
REDDIT_SESSION_COOKIE=your_reddit_session_cookie_value

# Google Apps Script Web App URL (deploy gas/Logger.gs, copy the /exec URL)
GAS_LOG_URL=https://script.google.com/macros/s/YOUR_DEPLOYMENT_ID/exec

# Set to "true" for verbose console output
DEBUG=true
